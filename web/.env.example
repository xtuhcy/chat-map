# Chat Map · Web UI configuration
# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
#
# NOTE: nothing in this file is sent to the browser. The only fields
# the browser sees are `AMAP_KEY` and `AMAP_SECURITY_CODE` (because
# the AMap JS API requires them in-browser to load tiles).

# ===== AMap (browser-visible via Jinja) =====
# Get from https://lbs.amap.com/  (高德地图开放平台)
AMAP_KEY=replace-with-your-amap-js-api-key
AMAP_SECURITY_CODE=replace-with-your-amap-security-code

# ===== LLM (server-side only) =====
# OpenAI-compatible endpoint.
LLM_API_KEY=replace-with-your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=MiniMax-M2.7
# Reasoning depth for reasoning-capable models (deepseek-v4-flash, o3,
# gpt-5.x, ...). One of: minimal | low | medium | high | xhigh.
# Leave unset / "" / "off" / "none" to keep thinking DISABLED — the
# request payload is then byte-identical to pre-knob behaviour.
# The model must natively support reasoning for this to have any
# effect; non-reasoning models silently ignore the parameter.
# LLM_REASONING_EFFORT=medium

# ===== Backend ports (bound to 127.0.0.1; not reachable from the network) =====
BROWSER_USE_HOST=127.0.0.1
BROWSER_USE_PORT=8765
MCP_HOST=127.0.0.1
MCP_PORT=8766

# ===== Web (public-facing) =====
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Used to validate the Origin header on WS upgrade (CSRF defense).
# Comma-separated list — browsers treat `localhost` and `127.0.0.1` as
# different origins, so list both for local dev. Use `*` to allow any
# (dev only — never in production).
WEB_PUBLIC_ORIGIN=http://localhost:8000,http://127.0.0.1:8000

# ===== Misc =====
# Per-command timeout for BrowserUseServer (seconds).
COMMAND_TIMEOUT=60.0
# How long to wait for the MCP server to bind on startup.
MCP_READY_TIMEOUT=5.0
# HMAC secret for /api/session user_token signing. CHANGE THIS IN PROD.
USER_TOKEN_SECRET=change-me-in-prod-please

# ===== WeChat Mini Program (server-side only; enables POST /api/wx-login) =====
# Get from https://mp.weixin.qq.com/  (微信小程序后台 → 开发管理 → AppID / AppSecret).
# When both are empty, POST /api/wx-login returns 503 and the wxmp client
# surfaces a friendly error. The browser path is unaffected.
WX_APP_ID=replace-with-your-wx-appid
WX_APP_SECRET=replace-with-your-wx-appsecret
# HTTP timeout (seconds) for the upstream jscode2session call.
WX_LOGIN_TIMEOUT=5.0
# AMap Mini Program SDK key — served to the wxmp client via
# GET /api/wx-config. NEVER hardcode this in wxmp source: the
# .wxapkg can be trivially decompiled and any key inside it is
# exposed. Get the key from https://lbs.amap.com/ as a
# "Mini Program" type key (different from the web JS API key).
AMAP_WX_KEY=replace-with-your-amap-miniprogram-key
# Regex matched against the WebSocket Origin header to allow
# WeChat Mini Program clients. The wxmp always sends an Origin
# like `https://servicewechat.com/<APPID>/<version>/<runtime>`,
# which never matches WEB_PUBLIC_ORIGIN — we use a separate
# pattern. Set to empty string to disable wxmp WS access.
# WX_WS_ORIGIN_ALLOW_PATTERN=^https://servicewechat\.com/
